# Copy to .env and fill in. Defaults match the repo-root docker-compose.yml.

DATABASE_URL="postgresql://festify:festify@localhost:5432/festify_dev?schema=public"
REDIS_URL="redis://localhost:6379"

PORT=3001
NODE_ENV=development

PUBLIC_API_URL="http://localhost:3001"
APP_URL="http://localhost:3000"
REFERRAL_LINK_BASE="https://event.festify.io"

JWT_SECRET="dev-secret-change-in-production"

# DigitalOcean Spaces (S3-compatible object storage)
# Private bucket — clients read via presigned URLs issued by this service.
SPACES_REGION="sgp1"
SPACES_ENDPOINT="https://sgp1.digitaloceanspaces.com"
SPACES_BUCKET=""
SPACES_KEY=""
SPACES_SECRET=""

# Email delivery
# In production, use:
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_..."
# EMAIL_FROM="no-reply@yourdomain.com"
# EMAIL_FROM_NAME="Festify"
# APP_NAME="Festify"
EMAIL_PROVIDER=""
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_FROM_NAME="Festify"
APP_NAME="Festify"

# LUMA_WEBHOOK_SECRET=""
